# Copy to .env and fill in. Never commit the real .env.

# Required: signs cookies/tokens. Generate with:  openssl rand -base64 48
SECRET_KEY_BASE=

# Public hostname clients reach (for URL generation + federation origin).
PHX_HOST=localhost
PUBLIC_URL=http://localhost:4000

# Optional: enable the /admin web panel. Generate with:  openssl rand -hex 16
ADMIN_TOKEN=

# TURN (calls across strict NATs). TURN_SECRET must be the SAME for the relay and
# coturn. Generate with:  openssl rand -hex 32
# Replace the host with your TURN server's public hostname/IP.
TURN_URLS=turn:turn.example.com:3478,turn:turn.example.com:3478?transport=tcp
TURN_SECRET=

# Private-network knobs (optional): a sealed, invite-only org/gov relay.
# MEMBERSHIP_MODE=invite
# FEDERATION_MODE=closed
