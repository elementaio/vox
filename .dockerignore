**/node_modules
**/.git
**/cover
**/.elixir_ls
**/priv/static/app
apps/web/dist
*.db
*.db-*
*.key
apps/server/relay_identity.key
apps/server/*.db*
signaling_dev.db*
.DS_Store
**/.DS_Store
scratchpad
